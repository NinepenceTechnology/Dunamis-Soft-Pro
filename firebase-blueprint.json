{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with role-based access control.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager", "reception", "barber"] },
        "storeId": { "type": "string", "description": "ID of the store the user belongs to" }
      },
      "required": ["uid", "email", "role"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "System audit logs for security and tracking.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "action", "timestamp"]
    },
    "WorkSession": {
      "title": "Work Session",
      "description": "Time tracking for staff members.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "durationMs": { "type": "number" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "durationMs", "startTime", "endTime"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer information and loyalty data.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "hairType": { "type": "string" },
        "allergies": { "type": "string" },
        "loyalty": { "type": "string", "enum": ["New", "Regular", "VIP"] },
        "points": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phone"]
    },
    "Product": {
      "title": "Product",
      "description": "Inventory product.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "cost": { "type": "number" },
        "stock": { "type": "number" },
        "supplierId": { "type": "string" }
      },
      "required": ["name", "price", "stock"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Financial transaction record.",
      "type": "object",
      "properties": {
        "invoiceNumber": { "type": "string" },
        "customerId": { "type": "string" },
        "items": { "type": "array" },
        "subtotal": { "type": "number" },
        "tax": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "pending", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["invoiceNumber", "total", "status"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Product supplier information.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "contact": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["name"]
    }
  },
  "firestore": {
    "users/{uid}": { "schema": "User", "description": "User profiles" },
    "audit_logs/{logId}": { "schema": "AuditLog", "description": "System audit logs" },
    "work_sessions/{sessionId}": { "schema": "WorkSession", "description": "Staff work sessions" },
    "customers/{customerId}": { "schema": "Customer", "description": "Customer list" },
    "products/{productId}": { "schema": "Product", "description": "Product inventory" },
    "invoices/{invoiceId}": { "schema": "Invoice", "description": "Sales invoices" },
    "suppliers/{supplierId}": { "schema": "Supplier", "description": "Suppliers list" }
  }
}
